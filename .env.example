# ============================================================================
# Investa Offer Intelligence — example environment configuration
# Copy to ".env" and fill in real values:  cp .env.example .env
# Every variable below is read by backend/app/config.py (pydantic-settings).
# ============================================================================

# ---------------------------------------------------------------------------
# LLM provider (OpenAI-compatible).
# Default = GitHub Models: free, rate-limited, uses a GitHub Personal Access
# Token with the "models" permission. Endpoint is OpenAI-compatible, so you can
# swap to OpenAI / Azure OpenAI by changing only the three vars below.
# ---------------------------------------------------------------------------
LLM_BASE_URL=https://models.github.ai/inference
LLM_API_KEY=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx   # GitHub PAT with "models" scope
LLM_CHAT_MODEL=openai/gpt-4o-mini                 # extraction + scoring + reply
LLM_VISION_MODEL=openai/gpt-4o                    # optional image analysis
LLM_TEMPERATURE=0.1                               # low = deterministic
LLM_REQUEST_TIMEOUT=60                            # seconds
LLM_MAX_RETRIES=3

# To use OpenAI instead of GitHub Models:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_API_KEY=sk-...
#   LLM_CHAT_MODEL=gpt-4o-mini
#   LLM_VISION_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Database (PostgreSQL). The compose file provisions these automatically.
# ---------------------------------------------------------------------------
POSTGRES_USER=investa
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=offers
POSTGRES_HOST=postgres        # service name inside docker network
POSTGRES_PORT=5432
# Async SQLAlchemy URL (psycopg 3). Host=postgres inside compose, localhost outside.
DATABASE_URL=postgresql+psycopg://investa:change-me-in-prod@postgres:5432/offers

# ---------------------------------------------------------------------------
# External free data sources (keyless). Be a good API citizen: descriptive
# User-Agent + caching. Self-host these for production volumes.
# ---------------------------------------------------------------------------
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
WIKIDATA_BASE_URL=https://www.wikidata.org
WIKIPEDIA_BASE_URL=https://de.wikipedia.org
HTTP_USER_AGENT=InvestaOfferIntel/0.1 (KI Challenge prototype)   # OSM blocks placeholder/example UAs; use a real descriptive one
ENRICHMENT_CACHE_TTL_DAYS=30      # reuse cached external responses for N days

# ---------------------------------------------------------------------------
# Dedup / object-recognition thresholds (see pipeline/dedup.py).
# ---------------------------------------------------------------------------
DEDUP_ADDRESS_SIM_STRONG=0.88     # address similarity alone => match
DEDUP_ADDRESS_SIM_WEAK=0.75       # weak address + close geo => match
DEDUP_GEO_DISTANCE_M=150          # metres for the weak-match geo gate

# ---------------------------------------------------------------------------
# Scoring weights (final score = weighted blend, clamped 0..10).
# Also overridable via backend/app/pipeline/scoring.yaml.
# ---------------------------------------------------------------------------
SCORE_WEIGHT_LOCATION=0.30
SCORE_WEIGHT_PRICE=0.30
SCORE_WEIGHT_CONDITION=0.15
SCORE_WEIGHT_SIZE_USAGE=0.15
SCORE_WEIGHT_COMPLETENESS=0.10

# ---------------------------------------------------------------------------
# App / API
# ---------------------------------------------------------------------------
API_PORT=8000
UPLOAD_DIR=/data/uploads          # mounted volume inside the backend container
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Frontend (build-time). Browser talks to the backend through this base URL.
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=/api
